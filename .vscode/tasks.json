{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "type": "shell",
            "command": "${command:python.interpreterPath}",
            "args": [
                "-m",
                "PyInstaller",
                "race-results-client.spec",
                "--noconfirm",
                "--clean"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            }
        },
        {
            "label": "archive",
            "type": "shell",
            "command": "7z.exe",
            "args": [
                "a",
                "-tzip",
                "\"dist\\race-results-client_$(Get-Date -Format yyyy-MM-dd).zip\"",
                "dist\\race-results-client\\"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            }
        },
        {
            "label": "distribute",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "dependsOrder": "sequence",
            "dependsOn": [
                "build",
                "archive"
            ]
        },
        {
            "label": "generate_ui",
            "group": "none",
            "type": "shell",
            "command": "${workspaceFolder}\\.venv\\Scripts\\activate.ps1;${workspaceFolder}\\src\\race_results\\ui\\generate_ui_py.ps1",
            "options": {
                "cwd": "${workspaceFolder}\\src\\race_results\\ui",
            },
            "problemMatcher": []
        }
    ]
}